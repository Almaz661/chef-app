// ШефДом — Phase 1 Product Master schema
// See .kiro/specs/phase-1-product-master/design.md

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

// ---------- Units ----------

enum UnitKind {
  MASS
  VOLUME
  COUNT
  OTHER
}

model Unit {
  id   String   @id // 'g', 'kg', 'ml', 'l', 'tbsp', 'tsp', 'pcs', 'pinch'
  name String
  kind UnitKind

  productsBase    Product[]          @relation("ProductBaseUnit")
  ingredients     RecipeIngredient[]
  conversionsFrom UnitConversion[]   @relation("ConversionFromUnit")
  conversionsTo   UnitConversion[]   @relation("ConversionToUnit")
  queueItems      IngredientMatchQueue[]

  @@map("units")
}

model UnitConversion {
  id         String   @id @default(cuid())
  productId  String?
  product    Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  fromUnitId String
  fromUnit   Unit     @relation("ConversionFromUnit", fields: [fromUnitId], references: [id])
  toUnitId   String
  toUnit     Unit     @relation("ConversionToUnit", fields: [toUnitId], references: [id])
  factor     Decimal  @db.Decimal(18, 6)

  @@unique([productId, fromUnitId, toUnitId])
  @@map("unit_conversions")
}

// ---------- Products ----------

model Product {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  category      String?
  baseUnitId    String
  baseUnit      Unit     @relation("ProductBaseUnit", fields: [baseUnitId], references: [id])
  kcalPer100    Float?
  proteinPer100 Float?
  fatPer100     Float?
  carbsPer100   Float?
  tags          String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  aliases     ProductAlias[]
  conversions UnitConversion[]
  ingredients RecipeIngredient[]

  @@map("products")
}

model ProductAlias {
  id             String  @id @default(cuid())
  productId      String
  product        Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  text           String
  normalizedText String
  locale         String  @default("ru")
  createdAt      DateTime @default(now())

  @@unique([normalizedText, locale])
  @@index([productId])
  @@map("product_aliases")
}

// ---------- Recipes ----------

model Recipe {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  servings    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ingredients RecipeIngredient[]
  queueItems  IngredientMatchQueue[]

  @@map("recipes")
}

model RecipeIngredient {
  id        String  @id @default(cuid())
  recipeId  String
  recipe    Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Decimal @db.Decimal(18, 4)
  unitId    String
  unit      Unit    @relation(fields: [unitId], references: [id])
  rawText   String?
  note      String?
  position  Int     @default(0)

  @@index([recipeId])
  @@index([productId])
  @@map("recipe_ingredients")
}

// ---------- Matching queue ----------

model IngredientMatchQueue {
  id         String   @id @default(cuid())
  recipeId   String?
  recipe     Recipe?  @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  rawText    String
  parsedName String
  quantity   Decimal? @db.Decimal(18, 4)
  unitId     String?
  unit       Unit?    @relation(fields: [unitId], references: [id])
  reason     String   // 'no_match' | 'ambiguous'
  candidates Json?
  createdAt  DateTime @default(now())

  @@index([recipeId])
  @@index([reason])
  @@map("ingredient_match_queue")
}

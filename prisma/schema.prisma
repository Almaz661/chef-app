// ШефДом — Phase 1 Product Master schema
// See .kiro/specs/phase-1-product-master/design.md

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

// ---------- Units ----------

enum UnitKind {
  MASS
  VOLUME
  COUNT
  OTHER
}

model Unit {
  id   String   @id // 'g', 'kg', 'ml', 'l', 'tbsp', 'tsp', 'pcs', 'pinch'
  name String
  kind UnitKind

  productsBase     Product[]          @relation("ProductBaseUnit")
  ingredients      RecipeIngredient[]
  conversionsFrom  UnitConversion[]   @relation("ConversionFromUnit")
  conversionsTo    UnitConversion[]   @relation("ConversionToUnit")
  queueItems       IngredientMatchQueue[]
  shoppingItems    ShoppingListItem[]
  inventoryItems   InventoryItem[]
  // Phase 6.7 — back-relation: recipes that yield a prep batch in this unit.
  prepYieldRecipes Recipe[]           @relation("RecipePrepYieldUnit")

  @@map("units")
}

model UnitConversion {
  id         String   @id @default(cuid())
  productId  String?
  product    Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  fromUnitId String
  fromUnit   Unit     @relation("ConversionFromUnit", fields: [fromUnitId], references: [id])
  toUnitId   String
  toUnit     Unit     @relation("ConversionToUnit", fields: [toUnitId], references: [id])
  factor     Decimal  @db.Decimal(18, 6)

  @@unique([productId, fromUnitId, toUnitId])
  @@map("unit_conversions")
}

// ---------- Products ----------

model Product {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  category      String?
  baseUnitId    String
  baseUnit      Unit     @relation("ProductBaseUnit", fields: [baseUnitId], references: [id])
  kcalPer100    Float?
  proteinPer100 Float?
  fatPer100     Float?
  carbsPer100   Float?
  tags          String[] @default([])
  // Phase 6.7 — true for products that are produced by a PREP recipe
  // (homemade broths, doughs, sauces). Default false for store-bought
  // ingredients. See .kiro/specs/phase-6.7-preps/design.md.
  isPrep        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  aliases       ProductAlias[]
  conversions   UnitConversion[]
  ingredients   RecipeIngredient[]
  shoppingItems ShoppingListItem[]
  inventoryItems InventoryItem[]

  substitutionsFrom ProductSubstitution[] @relation("SubstitutionFrom")
  substitutionsTo   ProductSubstitution[] @relation("SubstitutionTo")

  // Phase 6.7 — back-relation from PREP recipes that produce this product.
  producedByRecipes Recipe[] @relation("RecipeProducesProduct")

  @@map("products")
}

model ProductAlias {
  id             String  @id @default(cuid())
  productId      String
  product        Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  text           String
  normalizedText String
  locale         String  @default("ru")
  createdAt      DateTime @default(now())

  @@unique([normalizedText, locale])
  @@index([productId])
  @@map("product_aliases")
}

// ---------- Recipes ----------

enum RecipeGroup {
  BREAKFAST   // Завтраки
  SOUP        // Супы
  MAIN        // Основные блюда
  SALAD       // Салаты
  BAKING      // Выпечка
  DESSERT     // Десерты
  DRINK       // Напитки
  PREP        // Заготовки  (Phase 6.7)
}

model Recipe {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  description String?
  servings    Int          @default(1)
  group       RecipeGroup?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Phase 6.7 — preps. Either ALL five fields are non-null (PREP recipe)
  // or ALL of them are null (regular recipe). The invariant is enforced
  // at the service layer + integrity tests.
  producesProductId   String?
  producesProduct     Product? @relation("RecipeProducesProduct", fields: [producesProductId], references: [id], onDelete: SetNull)
  prepYieldQuantity   Decimal? @db.Decimal(18, 4)
  prepYieldUnitId     String?
  prepYieldUnit       Unit?    @relation("RecipePrepYieldUnit", fields: [prepYieldUnitId], references: [id])
  prepDefaultLocation InventoryLocation?
  prepShelfLifeDays   Int?

  ingredients RecipeIngredient[]
  queueItems  IngredientMatchQueue[]
  menuRecipes MenuRecipe[]

  @@index([group])
  @@index([producesProductId])
  @@map("recipes")
}

model RecipeIngredient {
  id        String  @id @default(cuid())
  recipeId  String
  recipe    Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Decimal @db.Decimal(18, 4)
  unitId    String
  unit      Unit    @relation(fields: [unitId], references: [id])
  rawText   String?
  note      String?
  position  Int     @default(0)

  @@index([recipeId])
  @@index([productId])
  @@map("recipe_ingredients")
}

// ---------- Matching queue ----------

model IngredientMatchQueue {
  id         String   @id @default(cuid())
  recipeId   String?
  recipe     Recipe?  @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  rawText    String
  parsedName String
  quantity   Decimal? @db.Decimal(18, 4)
  unitId     String?
  unit       Unit?    @relation(fields: [unitId], references: [id])
  reason     String   // 'no_match' | 'ambiguous'
  candidates Json?
  createdAt  DateTime @default(now())

  @@index([recipeId])
  @@index([reason])
  @@map("ingredient_match_queue")
}


// ---------- Phase 2: Menu / Shopping / Inventory ----------

model Menu {
  id        String    @id @default(cuid())
  name      String
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  recipes       MenuRecipe[]
  shoppingLists ShoppingList[]

  @@map("menus")
}

model MenuRecipe {
  id           String    @id @default(cuid())
  menuId       String
  menu         Menu      @relation(fields: [menuId], references: [id], onDelete: Cascade)
  recipeId     String
  recipe       Recipe    @relation(fields: [recipeId], references: [id])
  servings     Int       @default(1)
  scheduledFor DateTime?
  position     Int       @default(0)
  cookedAt     DateTime?

  @@index([menuId])
  @@index([recipeId])
  @@index([cookedAt])
  @@map("menu_recipes")
}

enum ShoppingListStatus {
  ACTIVE
  CLOSED
}

model ShoppingList {
  id        String             @id @default(cuid())
  menuId    String?
  menu      Menu?              @relation(fields: [menuId], references: [id], onDelete: SetNull)
  status    ShoppingListStatus @default(ACTIVE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  closedAt  DateTime?

  items ShoppingListItem[]

  @@map("shopping_lists")
}

model ShoppingListItem {
  id                String       @id @default(cuid())
  shoppingListId    String
  shoppingList      ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  productId         String
  product           Product      @relation(fields: [productId], references: [id])
  quantity          Decimal      @db.Decimal(18, 4)
  unitId            String
  unit              Unit         @relation(fields: [unitId], references: [id])
  purchasedQuantity Decimal      @default(0) @db.Decimal(18, 4)
  purchasedAt       DateTime?
  note              String?
  position          Int          @default(0)

  @@index([shoppingListId])
  @@index([productId])
  @@map("shopping_list_items")
}

enum InventoryLocation {
  PANTRY
  FRIDGE
  FREEZER
}

model InventoryItem {
  id         String            @id @default(cuid())
  productId  String
  product    Product           @relation(fields: [productId], references: [id])
  quantity   Decimal           @db.Decimal(18, 4)
  unitId     String
  unit       Unit              @relation(fields: [unitId], references: [id])
  location   InventoryLocation @default(PANTRY)
  expiresAt  DateTime?
  acquiredAt DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([productId])
  @@index([productId, location])
  @@index([expiresAt])
  @@map("inventory_items")
}

enum InventoryTxnSource {
  PURCHASE
  CONSUMPTION
  ADJUSTMENT
  INITIAL
  PREP_PRODUCTION
}

model InventoryTxn {
  id        String             @id @default(cuid())
  productId String
  quantity  Decimal            @db.Decimal(18, 4)
  unitId    String
  source    InventoryTxnSource
  refType   String?
  refId     String?
  note      String?
  createdAt DateTime           @default(now())

  @@index([productId, createdAt])
  @@map("inventory_txns")
}



// ---------- Phase 6: Dietary Substitutions ----------

model ProductSubstitution {
  id              String  @id @default(cuid())
  productId       String
  substituteId    String
  product         Product @relation("SubstitutionFrom", fields: [productId],    references: [id], onDelete: Cascade)
  substitute      Product @relation("SubstitutionTo",   fields: [substituteId], references: [id], onDelete: Cascade)
  conversionRatio Decimal @default(1) @db.Decimal(18, 6)
  bidirectional   Boolean @default(true)
  note            String?
  createdAt       DateTime @default(now())

  @@unique([productId, substituteId])
  @@index([productId])
  @@index([substituteId])
  @@map("product_substitutions")
}
